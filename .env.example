# ════════════════════════════════════════════════════════════════════════════
# Email-Native Crypto Remittance — Environment Configuration
# ════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Legend:
#   🔴 REQUIRED  — Server won't function without this
#   🟡 IMPORTANT — Needed for production/full functionality  
#   🟢 OPTIONAL  — Has sensible defaults or graceful fallback
#
# ════════════════════════════════════════════════════════════════════════════


# ┌────────────────────────────────────────────────────────────────────────────┐
# │                              SERVER CONFIG                                  │
# └────────────────────────────────────────────────────────────────────────────┘

# 🟢 OPTIONAL — Port to run the server on (default: 3001)
PORT=3001

# 🟢 OPTIONAL — Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# 🟢 OPTIONAL — Node environment: development, production, test
NODE_ENV=development


# ┌────────────────────────────────────────────────────────────────────────────┐
# │                              PUBLIC URLS                                    │
# └────────────────────────────────────────────────────────────────────────────┘

# 🟡 IMPORTANT — Backend URL (for API calls and fallback claim links)
# Must be publicly accessible for webhooks and external API calls.
# Local dev: use cloudflared tunnel → cloudflared tunnel --url http://localhost:3001
# Production: your Railway/Render/VPS domain
BASE_URL=http://localhost:3001

# 🟡 IMPORTANT — Frontend URL (for claim links in emails)
# Where recipients land when clicking claim links.
# If not set, falls back to BASE_URL.
# Production: your Vercel/Netlify/static hosting domain
FRONTEND_URL=https://email-remittance-pro.vercel.app

# 🟢 OPTIONAL — Allowed CORS origins (comma-separated)
# Default: allows localhost + FRONTEND_URL
# Example: https://app.example.com,https://staging.example.com
ALLOWED_ORIGINS=


# ┌────────────────────────────────────────────────────────────────────────────┐
# │                           BLOCKCHAIN WALLETS                                │
# └────────────────────────────────────────────────────────────────────────────┘

# 🔴 REQUIRED — Primary wallet private key (pays gas, holds escrow funds)
# Generate: https://app.safe.global or MetaMask → Export Private Key
# ⚠️ NEVER commit this value. Keep in .env only.
WALLET_PRIVATE_KEY=0x_your_64_char_hex_private_key_here

# 🟢 OPTIONAL — Explicit server wallet address (derived from private key if not set)
# Useful for verification/logging without exposing the private key in logs
SERVER_WALLET_ADDRESS=0x_your_wallet_address_here

# 🟢 OPTIONAL — Separate Celo-specific private key (uses WALLET_PRIVATE_KEY if not set)
# Use if you want different wallets per chain
CELO_PRIVATE_KEY=


# ┌────────────────────────────────────────────────────────────────────────────┐
# │                              RPC ENDPOINTS                                  │
# └────────────────────────────────────────────────────────────────────────────┘

# 🟢 OPTIONAL — Celo Mainnet RPC (default: Celo Foundation public node)
# Free: https://forno.celo.org (rate-limited, fine for low volume)
# Paid: QuickNode, Alchemy, Infura for production throughput
CELO_RPC_URL=https://forno.celo.org

# 🟢 OPTIONAL — Legacy alias for CELO_RPC_URL
CELO_PROVIDER_URL=

# 🟢 OPTIONAL — Base Mainnet RPC (default: Base public node)
# Free: https://mainnet.base.org
# Paid: Alchemy (https://alchemy.com/base), QuickNode
BASE_RPC_URL=https://mainnet.base.org

# 🟢 OPTIONAL — Monad Mainnet RPC (default: official Monad node)
# Free: https://rpc.monad.xyz (also: rpc1.monad.xyz, rpc2.monad.xyz)
MONAD_RPC_URL=https://rpc.monad.xyz


# ┌────────────────────────────────────────────────────────────────────────────┐
# │                          CONTRACT ADDRESSES                                 │
# └────────────────────────────────────────────────────────────────────────────┘

# 🟢 OPTIONAL — Custom Celo escrow contract address (uses default if not set)
CELO_CONTRACT_ADDRESS=

# 🟢 OPTIONAL — Celo stablecoin address for cUSD operations
# Default: 0x765de816845861e75a25fca122bb6898b8b1282a (cUSD on Celo Mainnet)
CELO_STABLECOIN_ADDRESS=0x765de816845861e75a25fca122bb6898b8b1282a


# ┌────────────────────────────────────────────────────────────────────────────┐
# │                             EMAIL DELIVERY                                  │
# └────────────────────────────────────────────────────────────────────────────┘

# 🔴 REQUIRED — Resend API key for sending claim emails
# 1. Sign up free: https://resend.com
# 2. Create API key: https://resend.com/api-keys (Sending access)
# Free tier: 3,000 emails/month, 100/day
# Key format: re_xxxxxxxxx
RESEND_API_KEY=re_your_resend_api_key_here


# ┌────────────────────────────────────────────────────────────────────────────┐
# │                               DATABASE                                      │
# └────────────────────────────────────────────────────────────────────────────┘

# 🟢 OPTIONAL — SQLite database path (default: ./remittance.db)
# SQLite is zero-config, perfect for dev and low-medium volume.
# For high volume production, use PostgreSQL via DATABASE_URL instead.
DB_PATH=./remittance.db

# 🟢 OPTIONAL — PostgreSQL connection string (overrides DB_PATH if set)
# Format: postgresql://user:password@host:5432/database_name
# DATABASE_URL=postgresql://user:pass@localhost:5432/remittance


# ┌────────────────────────────────────────────────────────────────────────────┐
# │                              SECURITY                                       │
# └────────────────────────────────────────────────────────────────────────────┘

# 🟢 OPTIONAL — JWT secret for session tokens (auto-generated if not set)
# Generate: openssl rand -hex 32
# Required if running multiple server instances (shared secret needed)
JWT_SECRET=


# ┌────────────────────────────────────────────────────────────────────────────┐
# │                        MANDATE — POLICY ENGINE                              │
# └────────────────────────────────────────────────────────────────────────────┘
#
# Mandate enforces transaction policies (limits, rate limiting, compliance).
# Without these keys, a permissive fallback policy is used.
# https://mandate.md
#

# 🟢 OPTIONAL — Mandate Runtime Key (from Dashboard → Agents → Your Agent)
# Format: mndt_live_xxxxxxxxx
MANDATE_RUNTIME_KEY=

# 🟢 OPTIONAL — Mandate Agent ID (UUID from agent creation)
MANDATE_AGENT_ID=

# 🟢 OPTIONAL — Legacy alias for MANDATE_RUNTIME_KEY
MANDATE_API_KEY=

# 🟢 OPTIONAL — Custom Mandate API base URL (default: https://api.mandate.md)
MANDATE_BASE_URL=


# ┌────────────────────────────────────────────────────────────────────────────┐
# │                      VENICE AI — PRIVATE INFERENCE                          │
# └────────────────────────────────────────────────────────────────────────────┘
#
# Venice AI analyzes transactions for fraud risk with zero data retention.
# Without this key, fraud analysis is skipped (logs warning).
# https://venice.ai
#

# 🟢 OPTIONAL — Venice API Key
# 1. Sign up: https://venice.ai
# 2. Settings → API: https://venice.ai/settings/api
# Format: VENICE_INFERENCE_KEY_xxxxxxxxx
VENICE_API_KEY=


# ┌────────────────────────────────────────────────────────────────────────────┐
# │                    SELF PROTOCOL — ZK IDENTITY                              │
# └────────────────────────────────────────────────────────────────────────────┘
#
# Self Protocol enables zero-knowledge identity verification.
# Recipients prove they're real humans without revealing personal info.
# Without these keys, verification runs in demo mode (always passes).
# https://developer.self.xyz
#

# 🟢 OPTIONAL — Self Protocol App ID
SELF_APP_ID=

# 🟢 OPTIONAL — Self Protocol App Secret  
SELF_APP_SECRET=

# 🟢 OPTIONAL — Custom Self API URL (default: https://api.self.xyz/v2)
SELF_API_URL=


# ┌────────────────────────────────────────────────────────────────────────────┐
# │                       UNISWAP — SWAP & BRIDGE                               │
# └────────────────────────────────────────────────────────────────────────────┘
#
# Enables token swaps and cross-chain bridging via Uniswap.
# Without this key, swap quotes work but execution is disabled.
# https://app.uniswap.org/developer
#

# 🟢 OPTIONAL — Uniswap Developer API Key
# 1. Sign in: https://app.uniswap.org/developer
# 2. Create project and copy API key
UNISWAP_API_KEY=


# ════════════════════════════════════════════════════════════════════════════
#                              QUICK START
# ════════════════════════════════════════════════════════════════════════════
#
# Minimum viable setup (local development):
#
#   WALLET_PRIVATE_KEY=0x...     (your dev wallet)
#   RESEND_API_KEY=re_...        (free tier works)
#
# Production deployment adds:
#
#   BASE_URL=https://your-backend.railway.app
#   FRONTEND_URL=https://your-frontend.vercel.app
#   NODE_ENV=production
#
# Full-featured deployment adds:
#
#   VENICE_API_KEY=...           (fraud detection)
#   MANDATE_RUNTIME_KEY=...      (policy enforcement)
#   SELF_APP_ID=...              (identity verification)
#   UNISWAP_API_KEY=...          (swap execution)
#
# ════════════════════════════════════════════════════════════════════════════
