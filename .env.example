# ============================================================
# Email-Native Crypto Remittance on Celo — Environment Config
# ============================================================
# Copy this file to .env and fill in your values.
# cp .env.example .env
#
# REQUIRED fields are needed for the server to start.
# OPTIONAL fields unlock additional features when provided.
# All optional integrations auto-degrade to demo mode if absent.
# ============================================================

# ── Server ───────────────────────────────────────────────────
PORT=3001

# PUBLIC URL (REQUIRED for claim links to work outside localhost)
# Must be accessible from the internet — not localhost.
# See README "Deployment" section for how to get a public URL.
# Personal/demo: use `cloudflared tunnel --url http://localhost:3001`
# Production: your Railway/Render/VPS domain
BASE_URL=http://localhost:3001


# ── Blockchain Wallet (REQUIRED) ─────────────────────────────
# The private key for the agent's sending wallet.
# This wallet pays gas and holds funds for remittances.
# Generate a new wallet: https://app.safe.global or MetaMask
# WARNING: Never commit this value. .env is in .gitignore.
WALLET_PRIVATE_KEY=0x_your_private_key_here


# ── Celo RPC (default: Celo Foundation public node) ──────────
# Free: https://forno.celo.org (rate-limited)
# Paid: https://app.quicknode.com or https://alchemy.com
CELO_RPC_URL=https://forno.celo.org


# ── Base RPC (default: Base public node) ─────────────────────
# Free: https://mainnet.base.org
# Paid: https://alchemy.com/base or https://app.quicknode.com
BASE_RPC_URL=https://mainnet.base.org


# ── Monad RPC (default: official Monad node) ─────────────────
# Mainnet chain ID: 143
# Free: https://rpc.monad.xyz
# Also: https://rpc1.monad.xyz, https://rpc2.monad.xyz
MONAD_RPC_URL=https://rpc.monad.xyz


# ── Email Delivery via Resend (REQUIRED) ─────────────────────
# Resend sends the claim emails to recipients.
# 1. Sign up free at https://resend.com
# 2. Go to API Keys: https://resend.com/api-keys
# 3. Create key with "Sending access"
# Free tier: 3,000 emails/month, 100/day
RESEND_API_KEY=re_your_resend_api_key


# ── Database ─────────────────────────────────────────────────
# SQLite — zero config, file-based. Just provide a path.
# For production with high volume, migrate to PostgreSQL:
#   DATABASE_URL=postgresql://user:pass@host:5432/remittance
DB_PATH=./remittance.db


# ── Mandate Policy Engine (OPTIONAL — has fallback) ──────────
# Mandate enforces transaction policies: $100/tx, $1000/day limits.
# Without this key, a permissive fallback policy is used.
# 1. Sign up at https://mandate.md
# 2. Create an agent: Dashboard → Agents → New Agent
# 3. Copy your Runtime Key and Agent ID
MANDATE_RUNTIME_KEY=mndt_live_your_key_here
MANDATE_AGENT_ID=your-mandate-agent-id


# ── Venice AI — Private Inference (OPTIONAL) ─────────────────
# Venice analyzes each transaction for fraud risk.
# Zero data retention — no transaction details stored on Venice servers.
# Without this key, fraud analysis is skipped (not recommended for production).
# 1. Sign up at https://venice.ai
# 2. Go to Settings → API: https://venice.ai/settings/api
# 3. Create an API key
# Key format: VENICE_INFERENCE_KEY_xxxxxxxx
VENICE_API_KEY=VENICE_INFERENCE_KEY_your_key_here


# ── Self Protocol — ZK Identity Verification (OPTIONAL) ──────
# Self Protocol enables zero-knowledge identity verification.
# Recipients/senders prove they're real humans without revealing PII.
# Without these keys, verification runs in demo mode (always passes).
# 1. Register at https://developer.self.xyz
# 2. Create an App: Developer Portal → Apps → New App
# 3. Copy your App ID and App Secret
SELF_APP_ID=your-self-app-id
SELF_APP_SECRET=your-self-app-secret
# Optional: override API endpoint (default: https://api.self.xyz/v2)
# SELF_API_URL=https://api.self.xyz/v2


# ── Uniswap Trading API (OPTIONAL) ───────────────────────────
# Enables autonomous swap execution and cross-chain bridging via Uniswap.
# Without this key, swap quotes work but execution is disabled.
# 1. Go to https://app.uniswap.org/developer
# 2. Sign in and create a project
# 3. Copy your API key from the Developer Portal
# Universal Router deployed on: Celo, Base, Monad (chainId 143)
UNISWAP_API_KEY=your-uniswap-developer-api-key


# ── Node Environment ─────────────────────────────────────────
NODE_ENV=development
# NODE_ENV=production
