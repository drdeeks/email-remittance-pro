# ════════════════════════════════════════════════════════════════════════════
# Email Remittance Frontend — Environment Configuration
# ════════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env.local for Next.js:
#   cp .env.example .env.local
#
# All frontend env vars MUST be prefixed with NEXT_PUBLIC_ to be exposed
# to the browser. Non-prefixed vars are server-side only.
#
# ════════════════════════════════════════════════════════════════════════════


# ┌────────────────────────────────────────────────────────────────────────────┐
# │                             BACKEND API                                     │
# └────────────────────────────────────────────────────────────────────────────┘

# 🔴 REQUIRED — Backend API URL
# Points to your running email-remittance server.
#
# Local development:
#   NEXT_PUBLIC_API_URL=http://localhost:3001
#
# Production (Railway):
#   NEXT_PUBLIC_API_URL=https://email-remittance-pro-production.up.railway.app
#
# Production (Render):
#   NEXT_PUBLIC_API_URL=https://email-remittance.onrender.com
#
NEXT_PUBLIC_API_URL=http://localhost:3001


# ┌────────────────────────────────────────────────────────────────────────────┐
# │                           WALLET CONNECT                                    │
# └────────────────────────────────────────────────────────────────────────────┘

# 🟡 IMPORTANT — WalletConnect Project ID (for mobile wallet support)
# Required for RainbowKit to connect mobile wallets via QR code.
# Without this, only browser extension wallets (MetaMask, etc.) work.
#
# Get your free Project ID:
# 1. Go to: https://cloud.walletconnect.com
# 2. Create a new project
# 3. Copy the Project ID
#
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id


# ════════════════════════════════════════════════════════════════════════════
#                              QUICK START
# ════════════════════════════════════════════════════════════════════════════
#
# Local development (backend running on port 3001):
#
#   NEXT_PUBLIC_API_URL=http://localhost:3001
#   NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id
#
# Production (Vercel + Railway):
#
#   NEXT_PUBLIC_API_URL=https://your-backend.up.railway.app
#   NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id
#
# ════════════════════════════════════════════════════════════════════════════
